{
  "name": "garnish",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./extension": "./src/extension.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test tests/e2e/",
    "garnish": "bun src/bin.ts",
    "proto": "bun proto/main.ts",
    "proto:demo": "bun proto/demo.ts",
    "proto:live": "bun proto/main.ts --live",
    "demo:mp4": "vhs scripts/real-demo.tape",
    "demo:mp4:tui": "vhs scripts/real-demo-tui.tape",
    "proto:expedition": "bun proto/main.ts --ui expedition",
    "proto:dungeon": "bun proto/main.ts --ui dungeon",
    "proto:arcade": "bun proto/main.ts --ui arcade",
    "demo:mp4:expedition": "vhs scripts/real-demo-expedition.tape",
    "demo:mp4:dungeon": "vhs scripts/real-demo-dungeon.tape",
    "demo:mp4:arcade": "vhs scripts/real-demo-arcade.tape",
    "proto:factory": "bun proto/factory/main.ts",
    "proto:factory:demo": "bun proto/factory/demo.ts",
    "demo:mp4:factory": "vhs scripts/real-demo-factory.tape",
    "demo:mp4:factory:tui": "vhs scripts/real-demo-factory-tui.tape",
    "proto:factory:foreman": "bun proto/factory/main.ts --flow foreman",
    "proto:factory:cold": "bun proto/factory/main.ts --flow cold",
    "proto:factory:ghost": "bun proto/factory/main.ts --flow ghost",
    "demo:mp4:factory:foreman": "vhs scripts/real-demo-factory-foreman.tape",
    "demo:mp4:factory:cold": "vhs scripts/real-demo-factory-cold.tape",
    "demo:mp4:factory:ghost": "vhs scripts/real-demo-factory-ghost.tape"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.17",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "@opentui/core": "0.4.3",
    "@opentui/react": "0.4.3",
    "openai": "6.45.0",
    "react": "19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
